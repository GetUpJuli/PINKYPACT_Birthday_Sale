{% style %}
  .delivery-dates-text:has(.fromDate{{ id }}:empty) {
    /* display:none; */
  }
{% endstyle %}
{% assign shippingday = settings.ShippingDay %}
<p class="delivery-dates-text" data-ship="{{ shippingday }}" data-id="{{ id }}">
  <span class="dot-animation"></span>
  <span class="ship_information">
    {% unless only_free_gift %}
      <span class="cart-shipping"> Lieferung via E-Mail </span>
    {% else %}
      {% comment %}
        <span class="cart-shipping">
          {{ 'sections.cart.shipment_text' | t }}
        </span>
      {% endcomment %}
      <span class="main-shipping">Auf Lager - </span>
      {{ 'sections.cart.delivery_text' | t }}
      <strong>
        <span class="fromDate{{ id }}"></span> bis
        <span class="toDate{{ id }}"></span>
      </strong>
    {% endunless %}
  </span>
</p>

<script>
var months = ["01", "02", "03", "04", "05", "06", "07", "08", "09", "10", "11", "12"];
var germanDayNames = { 0: 'So.', 1: 'Mo.', 2: 'Di.', 3: 'Mi.', 4: 'Do.', 5: 'Fr.', 6: 'Sa.' };
var delivery_estimates = `delivery_estimates_1`;
var initCartTimer = `initCartTimer_1`;
async function fetchPublicHolidays() {
    const response = await fetch(`https://date.nager.at/api/v3/PublicHolidays/2025/DE`);
    const holidays = await response.json();
    return holidays.filter(h => h.types.includes("Public")).map(h => new Date(h.date));
}

function isPublicHoliday(date, holidays) {
    return holidays.some(holiday => holiday.toDateString() === date.toDateString());
}

window[delivery_estimates] = async () => {
    const today = new Date(); // Static date for testing 2025, 11, 24, 15, 0, 0
    let startDate = new Date(today);
    let endDate = new Date(today);
    const publicHolidays = await fetchPublicHolidays();
   
    // Adjust start and end dates based on Sunday and public holidays
    if (today.getDay() === 5) { 
        console.log('Today is Friday')
        if (isPublicHoliday(today, publicHolidays)) {
            startDate.setDate(startDate.getDate() + 4 + {{ shippingday }}); 
            console.log('Today is Friday === Move to Tuesday')
        } else if (today.getHours() >= 15) {
            startDate.setDate(startDate.getDate() + 4 + {{ shippingday }}); 
            console.log('Today is Friday === After 3 PM, next Tuesday')
        } else {
            startDate.setDate(startDate.getDate() + {{ shippingday }}); 
            console.log('Today is Friday === Otherwise, next Saturday')
        }
    } else if (today.getDay() === 0 && today.getHours() >= 15) { 
        startDate.setDate(startDate.getDate() + 2 + {{ shippingday }}); 
        console.log('Today is Sunday')
    } else if (isPublicHoliday(today, publicHolidays)) {  
        startDate.setDate(startDate.getDate() +  2 + {{ shippingday }}); 
        console.log('Today is Public Holiday')
    } else { 
        console.log('Today is Normal Day')
        if (today.getHours() >= 15) {
            startDate.setDate(startDate.getDate() +  {{ shippingday }} + 2); 
            // console.log('Today is Normal Day === After 3 PM, next day')
        } else {
            startDate.setDate(startDate.getDate() + {{ shippingday }});
            // console.log('Today is Normal Day === Before 3 PM, ShippingDay applies')
        } 
    }

   // Skip Sundays for the start date
    while (startDate.getDay() === 0 || isPublicHoliday(startDate, publicHolidays || !isPublicHoliday(today, publicHolidays))) {
        startDate.setDate(startDate.getDate() + 1);
    }

    // Set end date one day after start date
    endDate = new Date(startDate);
    endDate.setDate(endDate.getDate() + 1);

    // Skip Sundays and public holidays for the end date
    while (endDate.getDay() === 0 || isPublicHoliday(endDate, publicHolidays)) {
        endDate.setDate(endDate.getDate() + 1);
    }

    var dayNameStart = germanDayNames[startDate.getDay()];
    var dayNameEnd = germanDayNames[endDate.getDay()];
    var formattedStartDate = dayNameStart + " " + startDate.getDate() + "." + months[startDate.getMonth()];
    var formattedEndDate = dayNameEnd + " " + endDate.getDate() + "." + months[endDate.getMonth()];
    var fromDates = document.querySelectorAll('.fromDate' + '{{ id }}');
    var toDates = document.querySelectorAll('.toDate' + '{{ id }}');

    fromDates.forEach(function (element) {
        element.innerText = formattedStartDate;
    });
    toDates.forEach(function (element) {
        element.innerText = formattedEndDate;
    });
};
window[delivery_estimates]();

(function () {
  const CART_TIMER_KEY = 'cart_timer_start';
   var MAX_TIME = 30 * 60 * 1000; // 30 minutes    
  let tickId = null;
  let clearing = false;

  function startTimer() {
    localStorage.setItem(CART_TIMER_KEY, String(Date.now()));
    startTicking();
  }

  function getRemaining() {
    const start = Number(localStorage.getItem(CART_TIMER_KEY));
    if (!start) return 0;
    return Math.max(0, MAX_TIME - (Date.now() - start));
  }

  function setText(ms) {
    const el = document.getElementById('cart-timer');
    const wrap = document.querySelector('.count-down-timer');
    if (!el) return; // UI is optional
    const m = Math.floor(ms / 60000);
    const s = Math.floor((ms % 60000) / 1000);
    el.textContent = `Reserviert für ${m}:${s < 10 ? '0' : ''}${s} Min!`;
    if (wrap) wrap.style.display = 'flex';
  }

  function hideText() {
    const el = document.getElementById('cart-timer');
    const wrap = document.querySelector('.count-down-timer');
    if (el) el.textContent = '';
    if (wrap) wrap.style.display = 'none';
  }

  function stopTicking() {
    if (tickId) { clearInterval(tickId); tickId = null; }
  }

  function startTicking() {
    stopTicking();
    tickId = setInterval(() => {
      const rem = getRemaining();
      if (rem <= 0) {
        stopTicking();
        clearCartOnce();
        return;
      }
      setText(rem);
    }, 500);
  }

  function clearCartOnce() {
    if (clearing) return;
    clearing = true;

    // Remove items one-by-one via existing <cart-remove-button> controls
    const tryRemove = setInterval(() => {
      const btn = document.querySelector('cart-remove-button');
      if (btn) {
        btn.click();
      } else {
        clearInterval(tryRemove);
        destroyTimer();
        clearing = false;
        console.log('[cart-timer] cart empty & timer cleared');
      }
    }, 400);

    // Fallback: force clear after 5s in case buttons aren’t present
    setTimeout(() => {
      if (clearing) {
        fetch('/cart/clear.js', { method: 'POST' })
          .finally(() => { clearInterval(tryRemove); destroyTimer(); clearing = false; });
      }
    }, 5000);
  }

  function destroyTimer() {
    stopTicking();
    localStorage.removeItem(CART_TIMER_KEY);
    hideText();
  }

  function init() {
    stopTicking(); // avoid duplicates
    fetch('/cart.js', { cache: 'no-store' })
      .then(r => r.json())
      .then(cart => {
        if (cart && cart.items && cart.items.length > 0) {
          // Always restart timer on page load if cart has items
          startTimer();
        } else {
          destroyTimer();
        }
      })
      .catch(err => console.error('[cart-timer] init error', err));
  }

  // Expose for AJAX flows (call after add/remove/update)
  window.initCartTimer = init;

  // Run on load (covers both deferred & inline scripts)
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }

  // Resume ticking when tab becomes visible
  document.addEventListener('visibilitychange', () => {
    if (!document.hidden && localStorage.getItem(CART_TIMER_KEY)) startTicking();
  });

  // Optional: re-init after Shopify section reloads
  document.addEventListener('shopify:section:load', init);
  document.addEventListener('shopify:section:reorder', init);
})();

</script>
