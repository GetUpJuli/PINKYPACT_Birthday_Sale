let target = event.target;
if (target.tagName === "svg" || target.closest("svg")) {
target = button;
      }
document.querySelector('.np-tablinks.active').classList.remove('active');
document.querySelector(".np-tabcontent.active").classList.remove('active');
target.classList.add('active');
document.querySelector(`.np-tabcontent[data-value="${target.getAttribute("data-value")}"]`).classList.add('active');
    });
  });
}
