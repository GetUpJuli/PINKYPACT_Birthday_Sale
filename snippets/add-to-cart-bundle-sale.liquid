{% liquid
  assign first_load_count = product.selected_or_first_available_variant.metafields.custom.pair_number
%}
<script defer>
document.body.addEventListener('click', function (event) {
const picker = event.target.closest('.main-variant-picker');
if (picker) {
console.log('Clicked on .main-variant-picker');
const input = picker.querySelector('input');
if (input) {
input.click();
    }
  }
});
var nails,count,tabWrap,bundleWrapHeading,progressCount,progressBar,defaultImage,defaultThumbTitle,submitOpenButton,submitButton,submitButtonText;
document.addEventListener("DOMContentLoaded", function() {
generateBundleHTML({{first_load_count}});
});
// this function call in snippets/product-variant-options.liquid 
function OcmyFunction(options){
generateBundleHTML(options); 
}
function generateBundleHTML(pair_number_val) {
var variantSelects = document.querySelector('variant-selects');
var blackFridayWrap = document.querySelector(".np-bundle-wrap.np-bundle-wrap_design");
variantSelects.classList.add("loading-disable"); 
blackFridayWrap.classList.add("loading-disable");

// ✅ FIX: Bereits gewählte Farben VOR dem Neuaufbau speichern
const previousSelections = [];
document.querySelectorAll('.nail-product-data .variant_id').forEach(function (element) {
    const vid = element.getAttribute('value');
    if (!vid || vid === '55018575692102') return;
    previousSelections.push(vid);
});

let nailsHTML = '';
for (let i = 1; i <= pair_number_val; i++) {
if(document.querySelector('.variant_wrp input[type="radio"]:checked').getAttribute('pair_number') == 4 ){
nailsHTML += `
            <div class="np-nail" data-index="${i}">
              <div class="np-thumb-nail"><span class="remove">{% render 'bundle-remove-icon' %}</span>
                <img src="{{ 'DefaultNailNew.svg' | file_url }}" width="260" height="auto">
              </div>
              <p class="np-thumb-title">Farbe wählen</p>
            </div>`;
        }else if(document.querySelector('.variant_wrp input[type="radio"]:checked').getAttribute('pair_number') == 6 && i <= 5 ){        
nailsHTML += `
            <div class="np-nail" data-index="${i}">
              <div class="np-thumb-nail"><span class="remove">{% render 'bundle-remove-icon' %}</span>
                <img src="{{ 'DefaultNailNew.svg' | file_url }}" width="260" height="auto">
              </div>
              <p class="np-thumb-title">Farbe wählen</p>
            </div>`;      
        }else if(document.querySelector('.variant_wrp input[type="radio"]:checked').getAttribute('pair_number') == 9 && i <= 7 ){
nailsHTML += `
            <div class="np-nail" data-index="${i}">
              <div class="np-thumb-nail"><span class="remove">{% render 'bundle-remove-icon' %}</span>
                <img src="{{ 'DefaultNailNew.svg' | file_url }}" width="260" height="auto">
              </div>
              <p class="np-thumb-title">Farbe wählen</p>
            </div>`;
        }else{
nailsHTML += `
            <div class="np-nail selected-tab hide_remove_btn" data-index="${i}" data-variantid="55018575692102">
              <div class="np-thumb-nail"><span class="remove">{% render 'bundle-remove-icon' %}</span>
                <img src="https://cdn.shopify.com/s/files/1/0767/6051/4886/files/Design_ohne_Titel__43_-removebg-preview_ce0228a7-549f-45ed-9323-91beb59ebc0d.png?v=1772174342" width="260" height="auto">
              </div>
              <p class="np-thumb-title">Mystery Color</p>
            </div>`;
        }
    } 
document.querySelector('.bundle_wrp.active').classList.remove('active');
document.querySelector('.variant_wrp input:checked').closest('.bundle_wrp').classList.add('active');
const selectedRadioWrapper = document.querySelector('[name="Menge"]:checked')?.closest('.bundle_wrp');         
if (selectedRadioWrapper) {          
const existing = document.querySelector('.custom-append');
if (existing) existing.remove();                  
const newElement = document.createElement('div');
newElement.className = 'custom-append';
newElement.innerHTML = '<div class="np-nails bundle_btn np_wrp" id="np-nails" data-nails="' + pair_number_val + '">' + nailsHTML + '</div>';      
selectedRadioWrapper.parentNode.insertBefore(
newElement,
selectedRadioWrapper.nextSibling
          );
        }
let tubmwrap = ``;
for (let i = 1; i <= pair_number_val; i++) {
if(document.querySelector('.variant_wrp input[type="radio"]:checked').getAttribute('pair_number') == 4 ){
tubmwrap += `
            <div class="np-nail" data-index="${i}">
              <div class="np-thumb-nail"><span class="remove">{% render 'bundle-remove-icon' %}</span>
                <img src="{{ 'DefaultNailNew.svg' | file_url }}" width="260" height="auto">
              </div>
              <p class="np-thumb-title">Farbe wählen</p>
            </div>`;
        }else if(document.querySelector('.variant_wrp input[type="radio"]:checked').getAttribute('pair_number') == 6 && i <= 5 ){        
tubmwrap += `
            <div class="np-nail" data-index="${i}">
              <div class="np-thumb-nail"><span class="remove">{% render 'bundle-remove-icon' %}</span>
                <img src="{{ 'DefaultNailNew.svg' | file_url }}" width="260" height="auto">
              </div>
              <p class="np-thumb-title">Farbe wählen</p>
            </div>`;      
        }else if(document.querySelector('.variant_wrp input[type="radio"]:checked').getAttribute('pair_number') == 9 && i <= 7 ){
tubmwrap += `
            <div class="np-nail" data-index="${i}">
              <div class="np-thumb-nail"><span class="remove">{% render 'bundle-remove-icon' %}</span>
                <img src="{{ 'DefaultNailNew.svg' | file_url }}" width="260" height="auto">
              </div>
              <p class="np-thumb-title">Farbe wählen</p>
            </div>`;
        }else{
tubmwrap += `
            <div class="np-nail selected-tab np-nail-selected-tab" data-index="${i}" data-variantid="55018575692102">
              <div class="np-thumb-nail">
                <img src="https://cdn.shopify.com/s/files/1/0767/6051/4886/files/Design_ohne_Titel__43_-removebg-preview_ce0228a7-549f-45ed-9323-91beb59ebc0d.png?v=1772174342" width="260" height="auto">
              </div>
              <p class="np-thumb-title">Mystery Color</p>
            </div>`;
        }
      }
document.querySelectorAll('.np-tab-thubnail-wrapper').forEach(function(element) {
element.innerHTML = tubmwrap;
    });
let progressHTML = '';
for (let i = 1; i <= pair_number_val; i++) {
progressHTML += `<li class="np-progress-${i}"></li>`;
    }
document.querySelectorAll('.np-progress-bar').forEach(function(element) {
element.innerHTML = progressHTML;
    });
document.querySelectorAll(`.numberobjsex`).forEach(function(element) {
element.innerHTML = pair_number_val;
    });
document.querySelector('#np-bundle-wrap').dataset.nail = pair_number_val;
submitOpenButton = document.querySelector('.product-form__buttons');
submitButton = document.querySelector('.product-form__buttons .product-form__submit');
submitButtonText = submitButton.querySelector("span").innerText;
count = document.getElementById('selected-count');
nails = document.querySelectorAll('.custom-append #np-nails .np-nail');
tabWrap = document.getElementById('np-tab-wrap');
bundleWrapHeading = document.getElementById('np-bundle-wrap-heading');
progressCount = document.getElementById('np-current-progres');
progressBar = document.querySelectorAll('.np-tab-wrap .np-progress-bar li');
products = document.querySelectorAll('.np-product-card-wrap .np-pr-variant-card');
defaultImage = document.querySelectorAll('.np-thumb-nail img')[0].src;
defaultThumbTitle = document.querySelectorAll('.np-nail .np-thumb-title')[0].innerText;

// ✅ FIX: Bereits gewählte Farben direkt in neue Slots setzen (ohne .click())
const newAvailableNails = document.querySelectorAll('.custom-append #np-nails .np-nail:not([data-variantid])');
const newAvailableTabs = document.querySelectorAll('.np-tab-thubnail-wrapper .np-nail:not([data-variantid])');
previousSelections.slice(0, newAvailableNails.length).forEach(function(vid, i) {
    const card = document.querySelector('.np-pr-variant-card[data-vid="'+ vid +'"]');
    if (!card || !newAvailableNails[i]) return;
    const nail = newAvailableNails[i];
    nail.querySelector('img').src = card.querySelector('img').src;
    nail.querySelector('.np-thumb-title').innerText = card.querySelector('h3').textContent;
    nail.classList.add('selected-tab');
    nail.setAttribute('data-variantid', vid);
    nail.setAttribute('data-productHandle', card.dataset.handle);
    if (newAvailableTabs[i]) {
        newAvailableTabs[i].querySelector('img').src = card.querySelector('img').src;
        newAvailableTabs[i].querySelector('.np-thumb-title').innerText = card.querySelector('h3').textContent;
        newAvailableTabs[i].classList.add('selected-tab');
        newAvailableTabs[i].setAttribute('data-variantid', vid);
        newAvailableTabs[i].setAttribute('data-productHandle', card.dataset.handle);
    }
    var targetCards = document.querySelectorAll('.np-tabcontent .np-pr-variant-card[data-vid="'+ vid +'"]');
    targetCards.forEach(function(targetCard) {
        var mainCard = targetCard.closest('.main-np-pr-variant-card');
        if (mainCard) mainCard.classList.add('active');
    });
    if (progressBar[i]) progressBar[i].classList.add('active');
});
// Hidden Inputs für wiederhergestellte Farben + Mystery Colors neu generieren
let restoredHiddenHTML = '';
document.querySelectorAll('.bundle_btn .np-nail[data-variantid]').forEach(function (element, index) {
    const parent = element;
    const get_random_no = Math.floor(Math.random() * 100000);
    const vid = parent.dataset.variantid;
    if (vid === '55018575692102') {
        restoredHiddenHTML += `
            <input type="hidden" id="hidden-number${index + 1}" name="properties[uniqueId${index + 1}]" value="${get_random_no}">
            <input type="hidden" id="hidden-color${index + 1}" name="properties[Farbe ${index + 1}]" value="${parent.querySelector('.np-thumb-title').innerHTML}">
            <input type="hidden" id="hidden-variantID${index + 1}" name="properties[_VariantID${index + 1}]" value="55018575692102" class="variant_id">
            <input type="hidden" id="hidden-variantIMG${index + 1}" name="properties[_VariantImg${index + 1}]" value="https://cdn.shopify.com/s/files/1/0767/6051/4886/files/Design_ohne_Titel__43_-removebg-preview_ce0228a7-549f-45ed-9323-91beb59ebc0d.png?v=1772174342">
            <input type="hidden" id="hidden-producthandle${index + 1}" name="properties[_Producthandle${index + 1}]" value="mistery-color">
        `;
    } else {
        restoredHiddenHTML += `
            <input type="hidden" id="hidden-number${index + 1}" name="properties[uniqueId${index + 1}]" value="${get_random_no}">
            <input type="hidden" id="hidden-color${index + 1}" name="properties[Farbe ${index + 1}]" value="${parent.querySelector('.np-thumb-title').innerHTML}">
            <input type="hidden" id="hidden-variantID${index + 1}" name="properties[_VariantID${index + 1}]" value="${vid}" class="variant_id">
            <input type="hidden" id="hidden-variantIMG${index + 1}" name="properties[_VariantImg${index + 1}]" value="${parent.querySelector('img').src}">
            <input type="hidden" id="hidden-producthandle${index + 1}" name="properties[_Producthandle${index + 1}]" value="${parent.dataset.producthandle}">
        `;
    }
});
document.querySelector('.nail-product-data').innerHTML = '';
document.querySelector('.nail-product-data').insertAdjacentHTML('beforeend', restoredHiddenHTML);
if (progressCount) {
    const filledCount = document.querySelectorAll('.custom-append #np-nails .np-nail[data-variantid]').length;
    progressCount.innerText = filledCount;
}

if (bundleWrapHeading) {
bundleWrapHeading.querySelectorAll('.set-count')?.forEach(set =>{
set.innerText == nails.length;
      })
    }

// ✅ FIX: Overlay wird nur einmal erstellt
if (!document.querySelector('#np-overlay')) {
    const div = document.createElement('div');
    div.id = 'np-overlay';
    document.body.appendChild(div);
}

// ✅ FIX: Overlay Listener wird nur einmal gesetzt
const overlayEl = document.querySelector('#np-overlay');
if (overlayEl && !overlayEl.dataset.listenerAttached) {
    overlayEl.dataset.listenerAttached = 'true';
    overlayEl.addEventListener('click', () => {
        overlayEl.classList.remove('active');
        document.body.classList.remove('overlay-enable');
        tabWrap.classList.remove('active');
        document.querySelectorAll('.np-nail.selecting-tab')?.forEach(tab => {
            tab?.classList.toggle('selecting-tab');
        });
    });
}

const findSubmitButton = setInterval(() => {
if (submitButton) {
clearInterval(findSubmitButton);
submitButton.classList.add('np-disabled');
submitOpenButton?.addEventListener('click', (e)=>{
if (submitOpenButton.querySelector('.product-form__submit').classList.contains('np-disabled')) {
nails[0].click();
          }
        });
      }
if (document.querySelector('#np-nails').querySelectorAll('.np-nail:not([data-variantid])').length == 0){              
submitButton.classList.remove('np-disabled');
submitButton.removeAttribute('disabled','disabled');
      }else{
submitButton.classList.add('np-disabled'); 
submitButton.setAttribute('disabled','disabled');
      } 
    });   
// Variant Click
nails.forEach((nail) => {
nail.addEventListener('click', (e) => {
if (e.target.closest('.remove')) return;
if (e.target.closest('.np-nail')) {
const notSelectedNail = nail.closest('.bundle_btn').querySelectorAll('#np-nails .np-nail:not([data-variantid])');
if (notSelectedNail.length) {
let index = notSelectedNail[0].dataset.index;
let openTab = document.querySelectorAll(`.np-nail[data-index='${index}']`);
openTab.forEach(tab => {
tab.classList.add('selecting-tab');
            });
          }
for(var i=0;i<document.querySelector('.variant_wrp input[type="radio"]:checked').getAttribute('pair_number');i++){
if(document.querySelector('.variant_wrp input[type="radio"]:checked').getAttribute('pair_number') == 4 && i <= 2){
progressCount.innerText = (parseInt(document.querySelector('.variant_wrp input[type="radio"]:checked').getAttribute('pair_number')));
              }else if(document.querySelector('.variant_wrp input[type="radio"]:checked').getAttribute('pair_number') == 6  && i<1){
progressBar[i].classList.add('active');
progressCount.innerText = (parseInt(document.querySelector('.variant_wrp input[type="radio"]:checked').getAttribute('pair_number')));
              }else if(document.querySelector('.variant_wrp input[type="radio"]:checked').getAttribute('pair_number') == 9  && i <= 1){
progressBar[i].classList.add('active');
progressCount.innerText = (parseInt(document.querySelector('.variant_wrp input[type="radio"]:checked').getAttribute('pair_number')));
              }
            } 
tabWrap.classList.toggle('active');
document.querySelector('#np-overlay').classList.toggle('active');
document.body.classList.toggle('overlay-enable');         
        }
      });
    }); 

// ✅ FIX: Produkt-Karten Listener sauber neu setzen (keine Doppelung)
setProductClick();

// Default Tab Open
document.querySelector('.np-tab-remove').addEventListener('click', function () {
if(document.querySelector('.np-tab-wrap.active')){
document.querySelector('.np-tab-wrap.active').classList.remove('active');
      }
document.querySelector('#np-overlay').classList.remove('active');
document.body.classList.remove('overlay-enable');
document.querySelectorAll('.np-nail.selecting-tab')?.forEach(tab =>{
tab?.classList.toggle('selecting-tab');
      });
    });
document.querySelectorAll('.np-thumb-nail .remove').forEach((removeButton) => {
removeButton.addEventListener('click', function (e) {
e.preventDefault();
const thisRemoveAll = document.querySelectorAll(`.np-nail[data-index="${removeButton.closest('.np-nail').dataset.index}"]`);
var get_variant_all = removeButton.closest('.np-nail').dataset.variantid; 
var get_collection = removeButton.closest('.np-nail').dataset.collectionhandle;
var get_length = document.querySelectorAll(`.np-tab-thubnail-wrapper .np-nail[data-variantid="${get_variant_all}"]`).length - 1;           
if (get_length <= 0) {          
var targetCards = document.querySelectorAll(`.np-tabcontent .np-pr-variant-card[data-vid="${get_variant_all}"]`);          
targetCards.forEach(targetCard => {
var mainCard = targetCard.closest('.main-np-pr-variant-card');
if (mainCard) {
mainCard.classList.remove('active');
            }
          });
        }
const disableAllQty = e.target.closest('.np_wrp').querySelectorAll(`[data-vid="${thisRemoveAll[0].dataset.variantid}"]`);
let variantQty = 0;
if (disableAllQty.length) {
variantQty = disableAllQty[0].dataset.vqty;
        }
if (disableAllQty.length >= parseInt(variantQty)) {
disableAllQty.forEach(ele => {
ele.classList.remove('disabled');
          })
        }
thisRemoveAll?.forEach(takeOut => {
takeOut.querySelector('img').src = defaultImage;
takeOut.querySelector('.np-thumb-title').innerText = defaultThumbTitle;
takeOut.removeAttribute('data-variantid');
takeOut.classList.remove('selected-tab');
        });        
document.querySelectorAll('.np-nail')?.forEach(tab =>{
tab?.classList.remove('selecting-tab');
        });        
const notSelectedNail = removeButton.closest('.np_wrp').querySelectorAll('.np-nail:not([data-variantid])');
if(notSelectedNail.length) {
progressBar[(nails.length - notSelectedNail.length)].classList.remove('active');
progressCount.innerText = (nails.length - notSelectedNail.length);
if ((nails.length - notSelectedNail.length) < nails.length) {
bundleWrapHeading.classList.remove('complated');
          }
        }
if (notSelectedNail[0]) {
let selectNextTab = document.querySelectorAll(`.np-nail[data-index='${notSelectedNail[0].dataset.index}']`);
selectNextTab?.forEach(nextTab => {
nextTab.classList.add('selecting-tab');
          })
        }
let hiddenInputsHTML = '';               
document.querySelectorAll('.bundle_btn .np-nail[data-variantid]').forEach(function (element, index) {            
const parent = element;
const get_random_no = Math.floor(Math.random() * 100000);
if(document.querySelector('.variant_wrp input[type="radio"]:checked').getAttribute('pair_number') == 4 ){
hiddenInputsHTML += `
                <input type="hidden" id="hidden-number${index + 1}" name="properties[uniqueId${index + 1}]" value="${get_random_no}">
                <input type="hidden" id="hidden-color${index + 1}" name="properties[Farbe ${index + 1}]" value="${parent.querySelector('.np-thumb-title').innerHTML}">
                <input type="hidden" id="hidden-variantID${index + 1}" name="properties[_VariantID${index + 1}]" value="${parent.dataset.variantid}" class="variant_id">
                <input type="hidden" id="hidden-variantIMG${index + 1}" name="properties[_VariantImg${index + 1}]" value="${parent.querySelector('img').src}">
                <input type="hidden" id="hidden-producthandle${index + 1}" name="properties[_Producthandle${index + 1}]" value="${parent.dataset.producthandle}">
                `;
                }else if(document.querySelector('.variant_wrp input[type="radio"]:checked').getAttribute('pair_number') == 6 && index <= 5 ){
hiddenInputsHTML += `
                    <input type="hidden" id="hidden-number${index + 1}" name="properties[uniqueId${index + 1}]" value="${get_random_no}">
                    <input type="hidden" id="hidden-color${index + 1}" name="properties[Farbe ${index + 1}]" value="${parent.querySelector('.np-thumb-title').innerHTML}">
                    <input type="hidden" id="hidden-variantID${index + 1}" name="properties[_VariantID${index + 1}]" value="${parent.dataset.variantid}" class="variant_id">
                    <input type="hidden" id="hidden-variantIMG${index + 1}" name="properties[_VariantImg${index + 1}]" value="${parent.querySelector('img').src}">
                    <input type="hidden" id="hidden-producthandle${index + 1}" name="properties[_Producthandle${index + 1}]" value="${parent.dataset.producthandle}">
                `;
                }else if(document.querySelector('.variant_wrp input[type="radio"]:checked').getAttribute('pair_number') == 9 && index <= 7 ){
hiddenInputsHTML += `
                    <input type="hidden" id="hidden-number${index + 1}" name="properties[uniqueId${index + 1}]" value="${get_random_no}">
                    <input type="hidden" id="hidden-color${index + 1}" name="properties[Farbe ${index + 1}]" value="${parent.querySelector('.np-thumb-title').innerHTML}">
                    <input type="hidden" id="hidden-variantID${index + 1}" name="properties[_VariantID${index + 1}]" value="${parent.dataset.variantid}" class="variant_id">
                    <input type="hidden" id="hidden-variantIMG${index + 1}" name="properties[_VariantImg${index + 1}]" value="${parent.querySelector('img').src}">
                    <input type="hidden" id="hidden-producthandle${index + 1}" name="properties[_Producthandle${index + 1}]" value="${parent.dataset.producthandle}">
                `;
                }else{
hiddenInputsHTML += `
                    <input type="hidden" id="hidden-number${index + 1}" name="properties[uniqueId${index + 1}]" value="${get_random_no}">
                    <input type="hidden" id="hidden-color${index + 1}" name="properties[Farbe ${index + 1}]" value="${parent.querySelector('.np-thumb-title').innerHTML}">
                    <input type="hidden" id="hidden-variantID${index + 1}" name="properties[_VariantID${index + 1}]" value="55018575692102" class="variant_id">
                    <input type="hidden" id="hidden-variantIMG${index + 1}" name="properties[_VariantImg${index + 1}]" value="https://cdn.shopify.com/s/files/1/0767/6051/4886/files/Design_ohne_Titel__43_-removebg-preview_ce0228a7-549f-45ed-9323-91beb59ebc0d.png?v=1772174342">
                    <input type="hidden" id="hidden-producthandle${index + 1}" name="properties[_Producthandle${index + 1}]" value="mistery-color">
                `;
            }
        });
document.querySelector('.nail-product-data').innerHTML= ''; 
document.querySelector('.nail-product-data').insertAdjacentHTML('beforeend',hiddenInputsHTML);
submitButton.classList.add('np-disabled')
if(document.querySelector('.main-variant-picker input[pair_number="' + document.querySelectorAll('.bundle_btn .np-nail[data-variantid]').length + '"]') !== null){          
var get_id = document.querySelector('.main-variant-picker input[pair_number="' + document.querySelectorAll('.bundle_btn .np-nail[data-variantid]').length + '"]').getAttribute('data-variant_id');
document.querySelector('.product-variant-id').setAttribute('value',get_id);
        } 
      });
    });
const loadibgdisable = setInterval(() => {
variantSelects.classList.remove("loading-disable"); 
blackFridayWrap.classList.remove("loading-disable");
clearInterval(loadibgdisable);
      }, 1000);
  }

// ✅ FIX: Produkt-Klick Listener – klont Elemente um alte Listener zu entfernen
let setProductClick = function(){
// Alte Listener entfernen durch Klonen
document.querySelectorAll('.np-product-card-wrap .np-pr-variant-card').forEach(function(product) {
    const clone = product.cloneNode(true);
    product.parentNode.replaceChild(clone, product);
});
// Neue saubere Referenzen holen
const freshProducts = document.querySelectorAll('.np-product-card-wrap .np-pr-variant-card');
freshProducts.forEach((product) => {
product.addEventListener('click', (e) => {
if (e.target.closest('.np-pr-variant-card') || e.target.classList.contains('np-pr-variant-card')) {          
let parent = e.target.closest('.np-pr-variant-card');                         
var targetCards = document.querySelectorAll(`.np-tabcontent .np-pr-variant-card[data-vid="${parent.dataset.vid}"]`);        
targetCards.forEach(targetCard => {
var mainCard = targetCard.closest('.main-np-pr-variant-card');
if (mainCard) {
mainCard.classList.add('active');
            }
          });  
const checkQty = document.querySelector('.custom-append').querySelectorAll(`#np-nails .np-nail[data-variantid="${parent.dataset.vid}"]`);
const notSelectedNail = document.querySelector('.custom-append').querySelectorAll('#np-nails .np-nail:not([data-variantid])');
const disableAllQty = document.querySelector('.custom-append').querySelectorAll(`[data-vid="${parent.dataset.vid}"]`);
let index;    
if (checkQty.length >= parseInt(parent.dataset.vqty)) {
disableAllQty.forEach(ele => { ele.classList.add('disabled'); });
return
          }
if (notSelectedNail.length) {
let index = notSelectedNail[0].dataset.index;
tabWrap.setAttribute('data-index', index);
document.querySelectorAll(`.np-nail[data-index='${index}']`).forEach(tab => {
tab.querySelector('img').src = parent.querySelector('img').src;
tab.querySelector('.np-thumb-title').innerText = parent.querySelector('h3').textContent;
tab.classList.add('selected-tab');
tab.classList.remove('selecting-tab');   
progressBar[nails.length - notSelectedNail.length].classList.add('active');
progressCount.innerText = (nails.length - notSelectedNail.length) + 1;
if ((nails.length - notSelectedNail.length) + 1 == nails.length) {
bundleWrapHeading.classList.add('complated');
              }
tab.setAttribute('data-variantid', parent.dataset.vid);
tab.setAttribute('data-productHandle', parent.dataset.handle);
            });
if (notSelectedNail.length == 1) {
let selectedTabsCount = document.querySelectorAll('#np-nails .np-nail.selected-tab').length ;
tabWrap.classList.remove('active');
document.querySelector('#np-overlay').classList.remove('active');
document.body.classList.remove('overlay-enable');
            }
if (notSelectedNail[1]) {
