<script defer>
  let bundleCookie = document.cookie.match('(^|;) ?' + 'wishlists' + '=([^;]*)(;|$)');
  let wishlistElementArray = bundleCookie ? JSON.parse(bundleCookie[2]) : [];
  let parentDiv = document.querySelector('#np-tb-wishlist > div');
  let parenthead = document.querySelector('[data-value="wishlist"]');

  const checkStockWishlistStatus = async () => {
    try {
      let updatedWishlist = [];
      for (let item of wishlistElementArray) {
        let response = await fetch(`${location.origin}${item.handle}?sections=check-stock`);
        let data = await response.json();
        let parser = new DOMParser();
        let doc = parser.parseFromString(data["check-stock"], 'text/html');
        let stockStatus = doc.body.textContent.trim();
        if (stockStatus === 'inStock') {
          updatedWishlist.push(item);
        }
      }
      return updatedWishlist;
    } catch (error) {
      console.error('Error checking stock status:', error);
      return [];
    }
  };

  const renderWishlistItems = async () => {
    let inStockItems = await checkStockWishlistStatus();
    inStockItems.forEach(obj => {
      if (obj.tags.find(tag => tag !== 'sets_products') !== 'sets_products' && obj.quantity > 1) {
        const htmlElement = document.createElement('div');
        htmlElement.className = 'np-pr-variant-card';
        htmlElement.dataset.vqty = obj.quantity;
        htmlElement.dataset.vid = obj.var;

        const imgElement = document.createElement('img');
        imgElement.src = obj.image;

        const h3Element = document.createElement('h3');
        h3Element.className = 'np-pr-variant-card-title';
        h3Element.textContent = obj.title;

        if (obj.tags.find(tag => tag === 'Feet')) {
          const h4Element = document.createElement('div');
          const img1Element = document.createElement('img');
          img1Element.src = `{{ 'feet.png' | file_url }}`;
          h4Element.appendChild(img1Element);
          htmlElement.appendChild(h4Element);
        }

        htmlElement.appendChild(imgElement);
        htmlElement.appendChild(h3Element);

        parentDiv.appendChild(htmlElement);
      }
    });
    if (!parentDiv.children.length) {
      parentDiv.remove();
      parenthead.remove();
    }
    if(document.querySelector('#np-tb-wishlist .main-product-card-wrap')){
      setProductClick(parentDiv.querySelectorAll('.np-pr-variant-card'))
    }
  };
  renderWishlistItems(); 
</script>    
