rd h1 { color: {{ section.settings.wertcolor }}; font-size: {{ section.settings.wertsize }}px; line-height: {{ section.settings.wertsize }}px; font-family: {{ section.settings.wertfont.family }}; margin: 0px; } .gift-card p { font-size: 16px; line-height: 22px; color: black; margin: 0px 5px; font-family: sans-serif; } .gift-card h2 { color: {{ section.settings.codecolor }}; font-size: {{ section.settings.codesize }}px; line-height: {{ section.settings.codesize }}px; font-family: {{ section.settings.codefont.family }}; margin: 0px; } @media screen and (max-width: 640px) { .gift-card h1{ font-size: 100%; line-height: 100%; } .gift-card p{ font-size: 50%; line-height: 50%; } .gift-card h2{ font-size: 50%; line-height: 50%; } } .gift-card-download { padding: 9px 35px; border-radius: 50px; color: {{ section.settings.buttonfontcolor }}; background: {{ section.settings.buttoncolor }}; margin: 18px auto 0px auto; display: block; position: fixed; bottom: 36px; left: 50%; transform: translate(-50%, 0); max-width: 250px; font-family: sans-serif; font-size: 14px; text-align: center; line-height: 32px; text-decoration: none; box-shadow: 1px 1px 30px -4px rgba(64, 63, 61, .78); } @media print { .gift-card-download { display: none; } } </style> {% schema %} { "name": { "de": "Gutschein" }, "settings": [ { "type": "header", "content": "Gutscheindesign", "info": "Lade Dein fertiges Gutscheindesign hoch" }, { "type": "image_picker", "id": "gutscheindesign", "label": "Gutscheindesign" }, { "type": "header", "content": "Einstellungen", "info": "Verschiebe die dynamischen Elemente" }, { "type": "color", "id": "wertcolor", "label": "Wertfarbe", "default": "#000000" }, { "type": "font_picker", "id": "wertfont", "label": "Wert Schriftart", "default": "sans-serif" }, { "type": "text", "id": "wertsize", "label": "Wertgröße", "default": "42" }, { "type": "color", "id": "codecolor", "label": "Codefarbe", "default": "#000000" }, { "type": "font_picker", "id": "codefont", "label": "Wert Schrifta