<script>
document.addEventListener('DOMContentLoaded', () => {
  const hash = decodeURIComponent(location.hash || "");
  const variantIds = hash.match(/\d+/g) || [];
  if (!variantIds.length) return; 
  let index = 0;               
  const clickNextIfPossible = () => {
    while (index < variantIds.length) {
      const card = document.querySelector(`.np-pr-variant-card[data-vid="${variantIds[index]}"]`);
      if (!card) return false;  
      card.click();                  
      index += 1;
    }
    return true;         
  };
  if (clickNextIfPossible()) return; 
  const observer = new MutationObserver(() => {
    if (clickNextIfPossible()) observer.disconnect();
  });
  observer.observe(document.body, { childList: true, subtree: true });
  setTimeout(() => observer.disconnect(), 1500);
});
</script>