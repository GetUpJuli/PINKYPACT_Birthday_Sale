  // Drawer Collection arrow Slider buttopn 
   let scrollPosition = 0;
  const horizontalTabRow2 = document.querySelector('.np-tab-scroll');
  function slideLeft() {
      scrollPosition -= 200;
      if (scrollPosition < 0) {scrollPosition = 0;}
      horizontalTabRow2.scrollLeft = scrollPosition;
  }
  function slideRight() {
    scrollPosition += 200;
    if (scrollPosition > horizontalTabRow2.scrollWidth - horizontalTabRow2.offsetWidth) {
      scrollPosition = horizontalTabRow2.scrollWidth - horizontalTabRow2.offsetWidth;
    }
    horizontalTabRow2.scrollLeft = scrollPosition;
  }

  
