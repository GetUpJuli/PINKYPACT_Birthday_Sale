<style>
  .countdown-section {
    text-align: center;
    padding: 40px 20px;
    background-color: {{ section.settings.background_color }};
    color: {{ section.settings.text_color }};
  }
  .countdown-title {
    font-size: 2rem;
    margin-bottom: 20px;
    font-weight: bold;
  }
  .countdown-timer {
    display: flex;
    justify-content: center;
    gap: 10px;
    flex-wrap: wrap;
  }
  .countdown-block {
    background: {{ section.settings.timer_bg_color }};
    padding: 15px;
    border-radius: 8px;
    min-width: 60px;
  }
  .countdown-num {
    display: block;
    font-size: 2.5rem;
    font-weight: bold;
    color: {{ section.settings.num_color }};
  }
  .countdown-label {
    font-size: 0.8rem;
    text-transform: uppercase;
    margin-top: 5px;
  }
  .countdown-expired {
    font-size: 1.5rem;
    color: red;
  }
</style>

<div class="countdown-section color-{{ section.settings.color_scheme }} gradient">
  {% if section.settings.title != blank %}
    <h2 class="countdown-title">{{ section.settings.title }}</h2>
  {% endif %}

  <div id="countdown-display" class="countdown-timer">
    <!-- Timer-Blöcke werden per JS gefüllt -->
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const endDateStr = '{{ section.settings.end_date }}';
    // Füge Uhrzeit hinzu (z. B. 23:59 für Ende des Tages), falls nicht angegeben
    const endDateWithTime = endDateStr + (endDateStr.includes('T') ? '' : 'T23:59:00');
    const endDate = new Date(endDateWithTime).getTime();

    if (isNaN(endDate)) {
      document.getElementById('countdown-display').innerHTML = '<div class="countdown-expired">Ungültiges Enddatum!</div>';
      return;
    }

    function updateCountdown() {
      const now = new Date().getTime();
      const distance = endDate - now;

      const display = document.getElementById('countdown-display');
      if (distance < 0) {
        display.innerHTML = '<div class="countdown-expired">Abgelaufen!</div>';
        return;
      }

      const days = Math.floor(distance / (1000 * 60 * 60 * 24));
      const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
      const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
      const seconds = Math.floor((distance % (1000 * 60)) / 1000);

      display.innerHTML = `
        <div class="countdown-block">
          <span class="countdown-num">${days.toString().padStart(2, '0')}</span>
          <span class="countdown-label">Tage</span>
        </div>
        <div class="countdown-block">
          <span class="countdown-num">${hours.toString().padStart(2, '0')}</span>
          <span class="countdown-label">Stunden</span>
        </div>
        <div class="countdown-block">
          <span class="countdown-num">${minutes.toString().padStart(2, '0')}</span>
          <span class="countdown-label">Minuten</span>
        </div>
        <div class="countdown-block">
          <span class="countdown-num">${seconds.toString().padStart(2, '0')}</span>
          <span class="countdown-label">Sekunden</span>
        </div>
      `;
    }

    updateCountdown();
    setInterval(updateCountdown, 1000);
  });
</script>

{% schema %}
{
  "name": "Countdown Timer",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Titel (z. B. 'Sale endet bald!')",
      "default": "Sale endet bald!"
    },
    {
      "type": "text",
      "id": "end_date",
      "label": "Enddatum",
      "info": "Gib das Datum im Format YYYY-MM-DD ein (z. B. 2025-12-31 für Ende des Jahres). Der Timer endet um 23:59 Uhr dieses Tages.",
      "default": "2025-12-31"
    },
    {
      "type": "header",
      "content": "Farben"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Hintergrundfarbe",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Textfarbe",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "timer_bg_color",
      "label": "Timer-Block-Hintergrund",
      "default": "#f0f0f0"
    },
    {
      "type": "color",
      "id": "num_color",
      "label": "Zahlenfarbe",
      "default": "#333333"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Farbschema",
      "default": "background-1"
    }
  ],
  "presets": [
    {
      "name": "Countdown Timer"
    }
  ]
}
{% endschema %}