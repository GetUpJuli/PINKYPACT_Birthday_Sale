<style>
  .faq-section {
    padding: 0 0 80px;
  }
  .faq-section .page-width {
    max-width: 1180px;
    padding: 70px 15px;
    background: #FFF5F7;
  }
  .faq-title {
    margin-bottom: 48px;
    text-align: center;
  }
  .faq-title h2 {
    margin: 0 0 11px;
    color: #000;
    font-size: 40px;
    font-weight: 400;
    line-height: 58px;
  }
  .faq-title p {
    margin: 0;
    color: #000;
    font-size: 20px;
    font-weight: 400;
    line-height: 30px;
  }
  .faq-wrap {
    max-width: 780px;
    width: 100%;
    margin: 0 auto;
  }
  ul.accordion-list {
    margin: 0;
    padding: 0;
    list-style: none;
  }
  ul.accordion-list li:last-child {
    margin-bottom: 0;
  }
  ul.accordion-list li {
    margin-bottom: 10px;
    border-radius: 8px;
    background: #FEC8D6;
  }
  ul.accordion-list li h3 {
    cursor: pointer;
    padding: 12px 16px 12px 32px;
    font-family: "Quicksand", sans-serif;
    margin: 0;
    color: #000;
    font-size: 18px;
    font-weight: 500;
    line-height: 26px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 5px;
  }
  ul.accordion-list li .answer> *:last-child {
    margin-bottom: 0;
  }
  ul.accordion-list li .answer p {
    margin: 0 0 10px;
    color: #000;
    font-size: 15px;
    font-weight: 400;
    line-height: 26px;
  }
  ul.accordion-list li .answer {
    padding: 10px 16px 15px 32px;
  }
  @media only screen and (max-width: 1199px){
    .faq-section {
      padding: 0 0 70px;
    }
    .faq-title h2{
      font-size: 36px;
    }
  }
  @media only screen and (max-width: 989px){
    .faq-section {
      padding: 0 0 60px;
    }
    .faq-section .page-width {
      padding: 60px 15px;
    }
    .faq-title {
      margin-bottom: 40px;
    }
    .faq-title h2 {
      font-size: 36px;
    }
  }
  @media only screen and (max-width: 749px){
    .faq-section {
      padding: 0 0 50px;
    }
    .faq-section .page-width {
      padding-top: 32px;
      padding-bottom: 32px;
    }
    .faq-title {
      margin-bottom: 35px;
    }
    .faq-title h2 {
      margin-bottom: 8px;
      font-size: 28px;
      line-height: 34px;
    }
    .faq-title p {
      font-size: 16px;
      line-height: 20px;
    }
    ul.accordion-list li {
      margin-bottom: 12px;
    }
    ul.accordion-list li h3 {
      padding: 7px 18px 7px 12px;
      font-size: 14px;
    }
    ul.accordion-list li h3 svg {
      width: 20px;
      height: 20px;
    }
    ul.accordion-list li .answer {
      padding: 5px 18px 7px 12px;
    }
    ul.accordion-list li .answer p {
      margin-bottom: 5px;
      font-size: 14px;
      line-height: 24px;
    }
  }
  @media only screen and (max-width: 575px){
    .faq-section{
      padding-bottom: 30px;
    }    
  }
</style>

<div class="faq-section">
  <div class="page-width">
    <div class="faq-title">
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.info }}</p>
    </div>
    <div class="faq-wrap">
      <ul class="accordion-list">
        {% for block in section.blocks %}
        <li>
          <h3>
            {{ block.settings.faq_title }}
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M21 12C21 12.1989 20.921 12.3897 20.7803 12.5303C20.6397 12.671 20.4489 12.75 20.25 12.75H12.75V20.25C12.75 20.4489 12.671 20.6397 12.5303 20.7803C12.3897 20.921 12.1989 21 12 21C11.8011 21 11.6103 20.921 11.4697 20.7803C11.329 20.6397 11.25 20.4489 11.25 20.25V12.75H3.75C3.55109 12.75 3.36032 12.671 3.21967 12.5303C3.07902 12.3897 3 12.1989 3 12C3 11.8011 3.07902 11.6103 3.21967 11.4697C3.36032 11.329 3.55109 11.25 3.75 11.25H11.25V3.75C11.25 3.55109 11.329 3.36032 11.4697 3.21967C11.6103 3.07902 11.8011 3 12 3C12.1989 3 12.3897 3.07902 12.5303 3.21967C12.671 3.36032 12.75 3.55109 12.75 3.75V11.25H20.25C20.4489 11.25 20.6397 11.329 20.7803 11.4697C20.921 11.6103 21 11.8011 21 12Z" fill="#AE5781"/>
            </svg>
          </h3>
          <div class="answer" style="display:none;">
            {{ block.settings.faq_info }}
          </div>
        </li>
        {% endfor %}
      </ul>
    </div>
  </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.5.1/jquery.min.js"></script>
<script>
  $(document).ready(function(){
    $('.accordion-list > li > .answer').hide();
      
    $('.accordion-list > li').click(function() {
      if ($(this).hasClass("active")) {
        $(this).removeClass("active").find(".answer").slideUp();
      } else {
        $(".accordion-list > li.active .answer").slideUp();
        $(".accordion-list > li.active").removeClass("active");
        $(this).addClass("active").find(".answer").slideDown();
      }
      return false;
    });
    
  });
</script>

{% schema %}
  {
    "name": "FAQ Section",
    "settings": [
      {
        "type": "text",
        "id": "heading",
        "label": "Heading"
      },
      {
        "type": "textarea",
        "id": "info",
        "label": "Description"
      }
    ],
    "blocks": [
      {
        "type": "text",
        "name": "FAQ",
        "settings": [
          {
            "type": "text",
            "id": "faq_title",
            "label": "Heading"
          },
          {
            "type": "richtext",
            "id": "faq_info",
            "label": "Description"
          }
        ]
      }
    ],
    "presets": [
      {
        "name": "FAQ Section"
      }
    ]
  }
{% endschema %}