<style>
  .password-fullscreen-bg {
    min-height: 100vh;
    background: url('https://cdn.shopify.com/s/files/1/0767/6051/4886/files/Password_Banner_Black_Week_1.png?v=1772308255') center center / cover no-repeat fixed;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem 1rem;
    margin: 0;
  }

  .password-form-box {
    display: flex;
    gap: 2rem;
    flex-wrap: wrap;
    justify-content: center;
    max-width: 720px;
    width: 100%;
    margin-top: 5vh; /* Perfekt über "Ab Sonntag 11 Uhr" positioniert */
  }

  .password-input {
    flex: 1;
    min-width: 320px;
    padding: 1.5rem 2.2rem;
    font-size: 1.4rem;
    font-weight: 500;
    border: 3px solid rgba(255,255,255,0.5);
    border-radius: 24px;
    background: rgba(255,255,255,0.28);
    backdrop-filter: blur(16px);
    color: white;
    box-shadow: 0 12px 40px rgba(0,0,0,0.3);
  }

  .password-input::placeholder { color: rgba(255,255,255,0.9); }

  .password-button {
    padding: 1.5rem 5rem;
    font-size: 1.4rem;
    font-weight: 700;
    background: #ff69b4;
    color: white;
    border: none;
    border-radius: 24px;
    cursor: pointer;
    box-shadow: 0 12px 40px rgba(255,107,180,0.5);
    transition: all 0.3s ease;
  }

  .password-button:hover {
    background: #ff1493;
    transform: translateY(-6px);
    box-shadow: 0 18px 50px rgba(255,20,147,0.6);
  }

  @media (max-width: 480px) {
    .password-form-box {
      flex-direction: column;
      margin-top: 20vh;
    }
    .password-button { width: 100%; }
  }
</style>

<div class="password-fullscreen-bg">
  {%- form 'storefront_password' -%}
    <div class="password-form-box">
      <input
        type="password"
        name="password"
        id="Password"
        class="password-input"
        placeholder="Passwort eingeben..."
        autocomplete="current-password"
        required
      >
      <button name="commit" type="submit" class="password-button">
        Zugang erhalten
      </button>
    </div>
  {%- endform -%}
</div>

{% schema %}
{
  "name": "PINKYPACT Black Week",
  "settings": []
}
{% endschema %}